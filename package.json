{
  "name": "job-list-app",
  "version": "1.0.0",
  "description": "Job list application",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "concurrently -k -n BACK,FRONT -c blue,green \"npm -w backend run dev\" \"npm -w frontend run dev --silent\"",
    "build": "npm -w frontend run build",
    "start": "npm run build && NODE_OPTIONS=--no-warnings concurrently -k -n BACK,FRONT -c blue,green \"npm -w backend start\" \"npm -w frontend run preview -- --port 5000\"",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings=0",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/jest": "^30.0.0",
    "@types/lodash.isequal": "^4.5.8",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.3",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22 <23 || >=24"
  },
  "dependencies": {
    "lodash.isequal": "^4.5.0",
    "react-icons": "^5.5.0"
  }
}
